# Database
# Local development için SQLite
DATABASE_URL="file:./dev.db"

# Turso Database (Production için)
# Turso dashboard'dan alınacak: https://turso.tech/
TURSO_DATABASE_URL="libsql://your-database-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Authentication
AUTH_SECRET="your-random-secret-key-here-minimum-32-characters"
AUTH_TRUST_HOST=true

# NextAuth URL
# Local development
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel deploy sonrası otomatik ayarlanır)
# NEXTAUTH_URL="https://your-app.vercel.app"

# Google OAuth 2.0
# Google Cloud Console'dan alınacak: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App URL (production için)
# Vercel deploy sonrası otomatik ayarlanır
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

